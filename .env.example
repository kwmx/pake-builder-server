# --- The PUBLIC builder repo that holds .github/workflows/build.yml ---
# Making this repo PUBLIC is what makes builds free (unlimited Actions minutes
# on Linux, Windows AND macOS). A private repo works too but consumes metered
# minutes (macOS drains 10x).
GITHUB_OWNER=your-github-username
GITHUB_REPO=pake-builder

# --- Auth: a fine-grained Personal Access Token scoped to the builder repo ---
# Create at: https://github.com/settings/personal-access-tokens
#   Repository access : Only select repositories -> pake-builder
#   Permissions       : Actions = Read and write
#                       Contents = Read-only
#                       Metadata = Read-only  (auto-selected)
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# Workflow filename and branch (defaults are fine)
WORKFLOW_FILE=build.yml
GIT_REF=main
#Docker Server Port
SERVER_PORT=3000
